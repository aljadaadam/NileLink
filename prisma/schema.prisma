generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth Models ───────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  hashedPassword String
  company        String?
  phone          String?
  role           UserRole  @default(USER)
  locale         String    @default("en")
  emailVerified  Boolean   @default(false)
  verifyCode     String?
  verifyExpires  DateTime?
  plan           PlanType  @default(STARTER)
  trialEndsAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  routers        Router[]
  packages       Package[]
  vouchers       Voucher[]
  hotspotUsers   HotspotUser[]
  sessions       Session[]
  subscriptions  Subscription[]
  invoices       Invoice[]
  trustedDevices TrustedDevice[]
  adminLogs      AdminLog[]      @relation("AdminLogs")
  confirmedInvoices Invoice[]    @relation("ConfirmedBy")
  cardDesign     CardDesign?

  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─── Subscription & Billing ────────────────────────────────

enum PlanType {
  STARTER
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

model Subscription {
  id          String             @id @default(cuid())
  userId      String
  plan        PlanType
  status      SubscriptionStatus @default(TRIAL)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices    Invoice[]

  @@index([userId, status])
  @@map("subscriptions")
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique
  userId          String
  subscriptionId  String?
  plan            PlanType
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("USD")
  status          InvoiceStatus @default(PENDING)
  dueDate         DateTime
  paidAt          DateTime?
  periodStart     DateTime
  periodEnd       DateTime
  createdAt       DateTime      @default(now())

  confirmedById  String?
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  confirmedBy     User?         @relation("ConfirmedBy", fields: [confirmedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([confirmedById])
  @@map("invoices")
}

// ─── Router Models ─────────────────────────────────────────

model Router {
  id            String       @id @default(cuid())
  name          String
  host          String
  port          Int          @default(8728)
  username      String
  password      String
  apiKey        String       @unique
  status        RouterStatus @default(OFFLINE)
  lastSeen      DateTime?
  loginPageHtml     String?      @db.Text
  loginPageCss      String?      @db.Text
  loginPageTemplate String?      @default("modern")
  loginPageTitle    String?
  loginPageLogo     String?      @db.Text
  routerOsVersion   String?
  boardName         String?
  userId            String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotspotUsers  HotspotUser[]
  activeSessions HotspotSession[]

  @@index([userId])
  @@map("routers")
}

enum RouterStatus {
  ONLINE
  OFFLINE
  ERROR
}

// ─── Package Models ────────────────────────────────────────

model Package {
  id           String      @id @default(cuid())
  name         String
  nameAr       String?
  duration     Int?        // minutes
  dataLimit    BigInt?     // bytes
  uploadSpeed  Int?        // kbps
  downloadSpeed Int?       // kbps
  price        Decimal     @db.Decimal(10, 2)
  currency     String      @default("USD")
  isActive     Boolean     @default(true)
  userId       String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  vouchers     Voucher[]

  @@index([userId])
  @@map("packages")
}

// ─── Voucher Models ────────────────────────────────────────

model Voucher {
  id          String        @id @default(cuid())
  code        String        @unique
  status      VoucherStatus @default(UNUSED)
  packageId   String
  userId      String
  usedBy      String?
  usedAt      DateTime?
  expiresAt   DateTime?
  createdAt   DateTime      @default(now())

  package     Package       @relation(fields: [packageId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([status])
  @@map("vouchers")
}

enum VoucherStatus {
  UNUSED
  ACTIVE
  USED
  EXPIRED
}

// ─── Hotspot User Models ───────────────────────────────────

model HotspotUser {
  id            String          @id @default(cuid())
  username      String
  password      String
  routerId      String
  userId        String
  packageName   String?
  bytesIn       BigInt          @default(0)
  bytesOut      BigInt          @default(0)
  uptime        Int             @default(0) // seconds
  isActive      Boolean         @default(true)
  expiresAt     DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  router        Router          @relation(fields: [routerId], references: [id], onDelete: Cascade)
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions      HotspotSession[]

  @@unique([username, routerId])
  @@index([userId, isActive])
  @@map("hotspot_users")
}

model HotspotSession {
  id            String   @id @default(cuid())
  hotspotUserId String
  routerId      String
  ipAddress     String?
  macAddress    String?
  bytesIn       BigInt   @default(0)
  bytesOut      BigInt   @default(0)
  startedAt     DateTime @default(now())
  endedAt       DateTime?

  hotspotUser   HotspotUser @relation(fields: [hotspotUserId], references: [id], onDelete: Cascade)
  router        Router      @relation(fields: [routerId], references: [id], onDelete: Cascade)

  @@map("hotspot_sessions")
}

// ─── Admin Activity Log ────────────────────────────────────

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String   // CONFIRM_PAYMENT, CANCEL_INVOICE, DELETE_USER, TOGGLE_ROLE
  targetId  String?
  details   String?  @db.Text
  createdAt DateTime @default(now())

  admin     User     @relation("AdminLogs", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([createdAt])
  @@map("admin_logs")
}

// ─── Trusted Device (OTP bypass) ───────────────────────────

model TrustedDevice {
  id            String   @id @default(cuid())
  userId        String
  fingerprint   String   // hash of IP + User-Agent
  ipAddress     String?
  userAgent     String?
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fingerprint])
  @@index([userId])
  @@map("trusted_devices")
}

// ─── Card Design (Print Customization) ─────────────────────

model CardDesign {
  id              String   @id @default(cuid())
  userId          String   @unique
  logo            String?  @db.Text   // base64 data URL
  backgroundImage String?  @db.Text   // base64 data URL
  backgroundColor String?  @default("#f0fdfa")
  gradientTo      String?  @default("#ecfeff")
  borderColor     String?  @default("#0891b2")
  codeColor       String?  @default("#0e7490")
  brandText       String?  @default("NileLink WiFi")
  brandColor      String?  @default("#64748b")
  footerText      String?
  footerColor     String?  @default("#94a3b8")
  showPrice       Boolean  @default(true)
  showPackage     Boolean  @default(true)
  showQr          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("card_designs")
}
